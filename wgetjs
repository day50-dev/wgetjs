#!/usr/bin/env node

const { spawn, execSync } = require('child_process');
const { URL } = require('url');
const http = require('http');
const fs = require('fs');
const path = require('path');
const { quote: shellEscape } = require('shell-quote');
const getopts = require('getopts');

function usage() {
  console.error(`wgetjs - wget for SPAs and JavaScript-heavy websites

Usage: wgetjs [options] <url>

Download Control:
  -r                      Recursive download (follow links)
  -c                      Continue (resume partial downloads)
  -np                     No parent — don't ascend to parent directories
  -P, --workers=N         Number of parallel workers (default: 1)
  -l, --level=N           Max recursion depth (default: 5, 0 or 'inf' for infinite)
  -w, --wait=SECONDS      Wait SECONDS between retrievals
  --waitretry=SECONDS     Wait 1..SECONDS between retries (backoff)
  --random-wait           Randomize wait time (0.5×WAIT to 1.5×WAIT)

URL Filtering:
  -A, --accept=LIST       Accepted extensions (comma-separated, e.g., html,pdf)
  -R, --reject=LIST       Rejected extensions (comma-separated, e.g., jpg,png)
  --accept-regex=REGEX    Accept URLs matching regex
  --reject-regex=REGEX    Reject URLs matching regex
  --regex-type=TYPE       Regex type: 'posix' (default) or 'pcre'
  -D, --domains=LIST      Accepted domains (comma-separated)
  --exclude-domains=LIST  Rejected domains (comma-separated)
  -H, --span-hosts        Follow links to other hosts
  -L, --relative          Follow relative links only
  -I, --include-dirs=LIST Include only these directories
  -X, --exclude-dirs=LIST Exclude these directories
  --ignore-case         Ignore case when matching files/directories
  --post=CMD            Run CMD after each download ({} = downloaded file path)

Other:
  --method=CMD          Custom fetch command ({} = URL, appended by default)
  -h, --help              Show this help message

Examples:
  wgetjs -r -c -np http://example.com/
  wgetjs -r -A html,pdf -R jpg,png http://example.com/
  wgetjs -r -P 4 -l 3 http://example.com/
  wgetjs -r -D example.com,cdn.example.com http://example.com/
  wgetjs --method='curl -s {}' http://example.com/
  wgetjs --method='playwright fetch {}' http://example.com/
`);
  process.exit(1);
}

// Parse arguments using getopts (GNU getopt compatible)
const opts = getopts(process.argv.slice(2), {
  boolean: ['r', 'c', 'np', 'H', 'L', 'random-wait', 'ignore-case', 'h', 'help'],
  string: ['P', 'workers', 'l', 'level', 'w', 'wait', 'waitretry', 'A', 'accept', 'R', 'reject',
    'accept-regex', 'reject-regex', 'regex-type', 'D', 'domains', 'exclude-domains',
    'I', 'include-dirs', 'X', 'exclude-dirs', 'post', 'method', 'P'],
  alias: {
    'r': ['recursive'],
    'c': ['continue'],
    'np': ['no-parent'],
    'P': ['workers', 'directory-prefix'],
    'l': ['level'],
    'w': ['wait'],
    'A': ['accept'],
    'R': ['reject'],
    'D': ['domains'],
    'H': ['span-hosts'],
    'L': ['relative'],
    'I': ['include-dirs'],
    'X': ['exclude-dirs'],
    'h': ['help'],
  },
  default: {
    workers: 1,
    level: 5,
    wait: 0,
    'regex-type': 'posix',
  },
});

if (opts.help) {
  usage();
}

// Extract options
const startUrl = opts._[0];
if (!startUrl) {
  console.error('Error: URL is required');
  usage();
}

let startUrlWithScheme = startUrl;
if (!/^https?:\/\//i.test(startUrlWithScheme)) {
  startUrlWithScheme = 'http://' + startUrlWithScheme;
}

const startParsed = new URL(startUrlWithScheme);

// Convenience variables from parsed options
const recursive = opts.r;
const noParent = opts.np;
const continueMode = opts.c;
const parallelism = parseInt(opts.workers, 10);
const maxDepth = (opts.level === 'inf' || opts.level === '0') ? Infinity : parseInt(opts.level, 10);
const waitSeconds = parseFloat(opts.wait) || 0;
const waitRetry = parseFloat(opts.waitretry) || 0;
const randomWait = opts['random-wait'];
const method = opts.method;
const postCommand = opts.post;
const spanHosts = opts.H;
const relativeOnly = opts.L;
const ignoreCase = opts['ignore-case'];

// Filter options - handle arrays and comma-separated values
const acceptExts = opts.accept ? opts.accept.split(',').map(s => s.trim().toLowerCase()).filter(Boolean) : null;
const rejectExts = opts.reject ? opts.reject.split(',').map(s => s.trim().toLowerCase()).filter(Boolean) : null;
const acceptRegex = opts['accept-regex'] || null;
const rejectRegex = opts['reject-regex'] || null;
const regexType = opts['regex-type'] || 'posix';
const allowedDomains = opts.domains ? opts.domains.split(',').map(s => s.trim().toLowerCase()).filter(Boolean) : null;
const excludedDomains = opts['exclude-domains'] ? opts['exclude-domains'].split(',').map(s => s.trim().toLowerCase()).filter(Boolean) : null;
const includeDirs = opts['include-dirs'] ? opts['include-dirs'].split(',').map(s => s.trim()).filter(Boolean) : null;
const excludeDirs = opts['exclude-dirs'] ? opts['exclude-dirs'].split(',').map(s => s.trim()).filter(Boolean) : null;

// Validate options
if (regexType !== 'posix' && regexType !== 'pcre') {
  console.error('Error: --regex-type must be posix or pcre');
  process.exit(1);
}
if (!parallelism || parallelism < 1) {
  console.error('Error: -P/--workers requires a positive integer');
  process.exit(1);
}
if (isNaN(maxDepth) || maxDepth < 0) {
  console.error('Error: -l/--level requires a non-negative integer or 0/inf for infinite');
  process.exit(1);
}
if (isNaN(waitSeconds) || waitSeconds < 0) {
  console.error('Error: -w/--wait requires a non-negative number');
  process.exit(1);
}
if (isNaN(waitRetry) || waitRetry < 0) {
  console.error('Error: --waitretry requires a non-negative number');
  process.exit(1);
}

// --- CDP browser session ---

function launchChrome() {
  return new Promise((resolve, reject) => {
    const proc = spawn('google-chrome', [
      '--headless',
      '--disable-gpu',
      '--no-sandbox',
      '--remote-debugging-port=0',
    ], { stdio: ['pipe', 'pipe', 'pipe'] });

    let stderr = '';
    proc.stderr.on('data', (chunk) => {
      stderr += chunk.toString();
      const match = stderr.match(/DevTools listening on (ws:\/\/[^\s]+)/);
      if (match) {
        resolve({ proc, wsUrl: match[1] });
      }
    });
    proc.on('error', reject);
    proc.on('exit', (code) => {
      if (!stderr.includes('DevTools listening on')) {
        reject(new Error(`Chrome exited (${code}) before reporting DevTools URL.\n${stderr}`));
      }
    });
    setTimeout(() => reject(new Error('Chrome launch timed out')), 15000);
  });
}

function cdpSend(session, method, params = {}) {
  return new Promise((resolve, reject) => {
    const id = ++session._nextId;
    const handler = (ev) => {
      const msg = JSON.parse(ev.data);
      if (msg.id === id) {
        session.ws.removeEventListener('message', handler);
        if (msg.error) reject(new Error(msg.error.message));
        else resolve(msg.result);
      }
    };
    session.ws.addEventListener('message', handler);
    session.ws.send(JSON.stringify({ id, method, params }));
  });
}

function cdpWaitEvent(session, eventName, timeout = 30000) {
  return new Promise((resolve, reject) => {
    const timer = setTimeout(() => {
      session.ws.removeEventListener('message', handler);
      reject(new Error(`Timeout waiting for ${eventName}`));
    }, timeout);
    const handler = (ev) => {
      const msg = JSON.parse(ev.data);
      if (msg.method === eventName) {
        clearTimeout(timer);
        session.ws.removeEventListener('message', handler);
        resolve(msg.params);
      }
    };
    session.ws.addEventListener('message', handler);
  });
}

function httpJson(url, reqMethod = 'GET') {
  return new Promise((resolve, reject) => {
    const parsed = new URL(url);
    const req = http.request({
      hostname: parsed.hostname,
      port: parsed.port,
      path: parsed.pathname + parsed.search,
      method: reqMethod,
    }, (res) => {
      let body = '';
      res.on('data', (c) => body += c);
      res.on('end', () => {
        try { resolve(JSON.parse(body)); }
        catch (e) { reject(new Error(`Bad JSON from ${url}: ${body.slice(0, 200)}`)); }
      });
    });
    req.on('error', reject);
    req.end();
  });
}

async function createCdpSession(browserWsUrl) {
  const parsed = new URL(browserWsUrl);
  const base = `http://${parsed.host}`;

  const target = await httpJson(`${base}/json/new?about:blank`, 'PUT');
  const pageWsUrl = target.webSocketDebuggerUrl;

  const ws = new WebSocket(pageWsUrl);
  await new Promise((resolve, reject) => {
    ws.addEventListener('open', resolve);
    ws.addEventListener('error', reject);
  });

  const session = { ws, _nextId: 0 };
  await cdpSend(session, 'Page.enable');
  await cdpSend(session, 'Network.enable');
  return session;
}

async function cdpFetchPage(session, url) {
  // Capture the raw HTML response for link extraction
  let rawSource = null;
  const responseHandler = (ev) => {
    const msg = JSON.parse(ev.data);
    if (msg.method === 'Network.responseReceived') {
      const resp = msg.params.response;
      if (resp.url === url && resp.mimeType && resp.mimeType.includes('html')) {
        session._mainRequestId = msg.params.requestId;
      }
    }
  };
  session.ws.addEventListener('message', responseHandler);

  const loadPromise = cdpWaitEvent(session, 'Page.loadEventFired');
  await cdpSend(session, 'Page.navigate', { url });
  await loadPromise;

  session.ws.removeEventListener('message', responseHandler);

  // Get the raw source from the network response
  if (session._mainRequestId) {
    try {
      const body = await cdpSend(session, 'Network.getResponseBody', {
        requestId: session._mainRequestId,
      });
      rawSource = body.base64Encoded
        ? Buffer.from(body.body, 'base64').toString('utf-8')
        : body.body;
    } catch {}
    session._mainRequestId = null;
  }

  await new Promise((r) => setTimeout(r, 200));
  const result = await cdpSend(session, 'Runtime.evaluate', {
    expression: 'document.documentElement.outerHTML',
    returnByValue: true,
  });
  const rendered = result.result.value;
  return { rendered, rawSource: rawSource || rendered };
}

// --- Fallback: exec per invocation for custom --method ---

function execFetchPage(url) {
  let cmd;
  if (method.includes('{}')) {
    // Use {} substitution syntax (consistent with --post)
    cmd = method.replace(/\{\}/g, shellEscape([url]));
  } else {
    // Legacy behavior: append URL at the end
    cmd = `${method} ${shellEscape([url])}`;
  }
  try {
    const html = execSync(cmd, {
      encoding: 'utf-8',
      timeout: 30000,
      stdio: ['pipe', 'pipe', 'pipe'],
    });
    return { rendered: html, rawSource: html };
  } catch (e) {
    console.error(`  Failed to fetch: ${url}`);
    return null;
  }
}

// --- Shared utilities ---

// Wait function implementing wget-style timing options
// - waitSeconds: base wait time between retrievals
// - waitRetry: for retries, wait 1..waitRetry seconds (exponential backoff style)
// - randomWait: if true, randomize wait time to 0.5*wait..1.5*wait
// - attempt: which retry attempt this is (1-based, used for waitretry backoff)
function applyWait(attempt = 1) {
  return new Promise((resolve) => {
    let waitTime = waitSeconds;

    // Apply randomization if --random-wait is set
    if (randomWait && waitTime > 0) {
      const variance = waitTime * 0.5;
      waitTime = waitTime - variance + (Math.random() * variance * 2);
    }

    // Apply waitretry backoff for retries (attempt > 1)
    if (waitRetry > 0 && attempt > 1) {
      // Cap at waitRetry, minimum of 1 second
      const backoffWait = Math.min(waitRetry, Math.max(1, attempt));
      waitTime = Math.max(waitTime, backoffWait);
    }

    if (waitTime > 0) {
      setTimeout(resolve, waitTime * 1000);
    } else {
      resolve();
    }
  });
}

function urlToFilePath(urlStr) {
  const parsed = new URL(urlStr);
  let pathname = parsed.pathname;
  if (pathname.endsWith('/')) pathname += 'index.html';
  return path.join(parsed.hostname, pathname);
}

// When saving a file, if the path conflicts with an existing directory,
// append .1 like wget does
function resolveConflict(filePath) {
  if (fs.existsSync(filePath)) {
    const stat = fs.statSync(filePath);
    if (stat.isDirectory()) {
      return filePath + '.1';
    }
  }
  return filePath;
}

// When creating a directory, if a file already exists at that path,
// rename the file with .1 suffix like wget does
function ensureDir(dirPath) {
  const parts = dirPath.split(path.sep);
  let current = '';
  for (const part of parts) {
    current = current ? path.join(current, part) : part;
    if (fs.existsSync(current)) {
      const stat = fs.statSync(current);
      if (stat.isFile()) {
        const renamed = current + '.1';
        fs.renameSync(current, renamed);
        console.log(`  Renamed: ${current} -> ${renamed} (conflict)`);
        fs.mkdirSync(current);
      }
    }
  }
  fs.mkdirSync(dirPath, { recursive: true });
}

function savePage(urlStr, html) {
  let filePath = urlToFilePath(urlStr);
  ensureDir(path.dirname(filePath));
  filePath = resolveConflict(filePath);
  fs.writeFileSync(filePath, html, 'utf-8');
  console.log(`  Saved: ${filePath}`);
  return filePath;
}

function runPostProcess(filePath) {
  if (!postCommand) return;
  
  // Substitute {} with the properly shell-escaped file path using shell-quote library
  const cmd = postCommand.replace(/\{\}/g, shellEscape([filePath]));
  
  try {
    execSync(cmd, {
      stdio: ['pipe', 'inherit', 'inherit'],
      timeout: 60000,
    });
  } catch (e) {
    console.error(`  Post-process failed: ${cmd}`);
  }
}

function extractLinks(html, baseUrl) {
  const links = new Set();
  const hrefRegex = /href\s*=\s*["']([^"'#]+)/gi;
  let match;
  while ((match = hrefRegex.exec(html)) !== null) {
    const raw = match[1];
    // Skip relative links (./foo, ../foo, bare paths) — SPA navigation
    // artifacts. Only follow absolute-path (/foo) or full URL hrefs.
    if (!raw.startsWith('/') && !raw.startsWith('http://') && !raw.startsWith('https://')) {
      continue;
    }
    try { links.add(new URL(raw, baseUrl).href); }
    catch {}
  }
  return links;
}

function hasPathCycle(pathname) {
  // Detect repeating path segment patterns like /a/b/a/b/
  const parts = pathname.split('/').filter(Boolean);
  for (let len = 1; len <= parts.length / 2; len++) {
    for (let start = 0; start + len * 2 <= parts.length; start++) {
      const seg = parts.slice(start, start + len).join('/');
      const next = parts.slice(start + len, start + len * 2).join('/');
      if (seg === next) return true;
    }
  }
  return false;
}

// --- URL Filtering ---

function matchRegex(str, pattern, type) {
  try {
    if (type === 'pcre') {
      return new RegExp(pattern).test(str);
    } else {
      // POSIX-style: convert basic patterns to JS regex
      // Handle * as .* and ? as .
      const converted = pattern
        .replace(/[.+^${}()|[\]\\]/g, '\\$&')  // escape special chars
        .replace(/\*/g, '.*')                  // * matches anything
        .replace(/\?/g, '.');                  // ? matches single char
      return new RegExp(converted).test(str);
    }
  } catch {
    return false;
  }
}

function matchPattern(str, pattern, ignoreCase = false) {
  // Match shell-style wildcard patterns: *, ?, [...]
  try {
    // Convert shell pattern to regex
    let regex = pattern
      .replace(/[.+^${}|[\]\\]/g, '\\$&')  // escape special chars except * ? [ ]
      .replace(/\?/g, '.')                  // ? matches single char
      .replace(/\*/g, '.*');                // * matches anything
    
    // Handle [...] character classes
    regex = regex.replace(/\[([^\]]+)\]/g, (match, chars) => {
      // Convert [abc] to (a|b|c) and [a-z] to character class
      if (chars.includes('-')) {
        // It's a range like [a-z]
        return `[${chars}]`;
      }
      // It's a list like [abc]
      return `[${chars}]`;
    });
    
    const flags = ignoreCase ? 'i' : '';
    return new RegExp('^' + regex + '$', flags).test(str);
  } catch {
    return false;
  }
}

function matchPatternList(str, patternList, ignoreCase = false) {
  // Check if string matches any pattern in the list
  for (const pattern of patternList) {
    if (matchPattern(str, pattern, ignoreCase)) {
      return true;
    }
  }
  return false;
}

function matchDirectory(urlPath, dirList, ignoreCase = false) {
  // Check if URL path matches any directory pattern (supports wildcards)
  // Each pattern can be a prefix or a wildcard pattern
  for (let dir of dirList) {
    // Normalize: ensure directory patterns end with /
    if (!dir.endsWith('/')) dir += '/';
    
    // Try exact prefix match first (with wildcard support)
    if (matchPattern(urlPath, dir + '*', ignoreCase)) {
      return true;
    }
    // Also match the directory path itself (without trailing content)
    if (matchPattern(urlPath, dir, ignoreCase)) {
      return true;
    }
  }
  return false;
}

function shouldFollow(urlStr) {
  try {
    const parsed = new URL(urlStr);

    // Protocol check
    if (parsed.protocol !== 'http:' && parsed.protocol !== 'https:') {
      return false;
    }

    // -L: relative links only - skip absolute URLs to other hosts or different base
    if (relativeOnly) {
      if (parsed.hostname !== startParsed.hostname) return false;
    }

    // -H span-hosts: if NOT set, only follow same-host links
    if (!spanHosts && parsed.hostname !== startParsed.hostname) {
      return false;
    }

    // Domain filtering: -D (allowed domains) - only applies when -H is set
    // Per wget.man: "Note that it does not turn on -H"
    if (spanHosts && allowedDomains && !allowedDomains.includes(parsed.hostname.toLowerCase())) {
      return false;
    }

    // Domain filtering: --exclude-domains
    if (excludedDomains && excludedDomains.includes(parsed.hostname.toLowerCase())) {
      return false;
    }

    // -np: no parent directory check
    if (noParent) {
      let basePath = startParsed.pathname;
      if (!basePath.endsWith('/')) basePath = path.posix.dirname(basePath) + '/';
      if (!parsed.pathname.startsWith(basePath)) return false;
    }

    // -I: include directories (with wildcard support)
    if (includeDirs && !matchDirectory(parsed.pathname, includeDirs, ignoreCase)) {
      return false;
    }

    // -X: exclude directories (with wildcard support)
    if (excludeDirs && matchDirectory(parsed.pathname, excludeDirs, ignoreCase)) {
      return false;
    }

    // Extension filtering: -A (accept) - supports wildcards like *.mp3
    if (acceptExts) {
      const ext = path.extname(parsed.pathname).toLowerCase().replace(/^\./, '');
      // Check if extension matches any accept pattern
      if (!matchPatternList(ext, acceptExts, ignoreCase)) return false;
    }

    // Extension filtering: -R (reject) - supports wildcards like *.jpg
    if (rejectExts) {
      const ext = path.extname(parsed.pathname).toLowerCase().replace(/^\./, '');
      // Check if extension matches any reject pattern
      if (matchPatternList(ext, rejectExts, ignoreCase)) return false;
    }

    // Regex filtering: --accept-regex
    if (acceptRegex && !matchRegex(urlStr, acceptRegex, regexType)) {
      return false;
    }

    // Regex filtering: --reject-regex
    if (rejectRegex && matchRegex(urlStr, rejectRegex, regexType)) {
      return false;
    }

    // Cycle detection
    if (hasPathCycle(parsed.pathname)) return false;

    return true;
  } catch {
    return false;
  }
}

function normalizeUrl(urlStr) {
  const parsed = new URL(urlStr);
  parsed.hash = '';
  return parsed.href;
}

// --- Work queue with wait/notify and proper termination signaling ---

class WorkQueue {
  constructor() {
    this._items = [];
    this._waiters = [];
    this._finished = false;
  }

  push(url) {
    if (this._finished) return;
    this._items.push(url);
    if (this._waiters.length > 0) this._waiters.shift()();
  }

  // Returns a URL or null if done
  async take() {
    while (true) {
      if (this._items.length > 0) return this._items.shift();
      if (this._finished) return null;
      await new Promise((resolve) => this._waiters.push(resolve));
      if (this._finished) return null;
    }
  }

  // Signal no more work will be added and wake all waiters
  finish() {
    if (this._finished) return;
    this._finished = true;
    for (const wake of this._waiters) wake();
    this._waiters = [];
  }

  get length() { return this._items.length; }
  get isDone() { return this._finished; }
}

// --- Worker pool ---

async function main() {
  const useCdp = !method;

  console.log(`Starting download from: ${startUrl}`);
  if (recursive) console.log('Recursive mode enabled');
  if (noParent) console.log('No-parent mode enabled');
  console.log(`Workers: ${parallelism}`);

  // Shared state
  const visited = new Set();
  const queue = new WorkQueue();
  const firstUrl = normalizeUrl(startUrl);
  visited.add(firstUrl);
  queue.push({ url: firstUrl, depth: 0 });

  // Launch Chrome instances (one per worker) if using CDP
  const chromeProcs = [];
  const sessions = [];

  // Cleanup function to kill all Chrome processes
  function cleanup() {
    for (const s of sessions) { try { s.ws.close(); } catch {} }
    for (const p of chromeProcs) { try { p.kill('SIGTERM'); } catch {} }
    // Force kill after a short delay if still running
    setTimeout(() => {
      for (const p of chromeProcs) { try { p.kill('SIGKILL'); } catch {} }
    }, 1000);
  }

  // Register cleanup handlers
  process.on('exit', cleanup);
  process.on('SIGINT', () => { cleanup(); process.exit(130); });
  process.on('SIGTERM', () => { cleanup(); process.exit(143); });
  process.on('uncaughtException', (err) => {
    console.error('Uncaught exception:', err.message);
    cleanup();
    process.exit(1);
  });

  if (useCdp) {
    console.log(`Launching ${parallelism} Chrome instance(s)...`);
    const launches = [];
    for (let i = 0; i < parallelism; i++) {
      launches.push(launchChrome().then(async ({ proc, wsUrl }) => {
        chromeProcs.push(proc);
        const session = await createCdpSession(wsUrl);
        sessions.push(session);
      }));
    }
    await Promise.all(launches);
    console.log('All Chrome instances ready.\n');
  } else {
    console.log(`Method: ${method}\n`);
  }

  let downloaded = 0;
  // Track pending work items - incremented on enqueue, decremented on complete
  let pending = 1;  // Start with 1 for the seed URL

  function enqueueLinks(html, baseUrl, depth) {
    if (depth >= maxDepth) return;
    for (const link of extractLinks(html, baseUrl)) {
      const normalized = normalizeUrl(link);
      if (!visited.has(normalized) && shouldFollow(normalized)) {
        visited.add(normalized);
        pending++;
        queue.push({ url: normalized, depth: depth + 1 });
      }
    }
  }

  function makeFetchPage(workerIdx) {
    if (useCdp) {
      const session = sessions[workerIdx];
      return (url) => cdpFetchPage(session, url).catch((e) => {
        console.error(`  [W${workerIdx}] Failed to fetch: ${url} — ${e.message}`);
        return null;
      });
    } else {
      return execFetchPage;
    }
  }

  async function worker(workerIdx) {
    const fetchPage = makeFetchPage(workerIdx);
    let lastDownloadTime = 0;

    while (true) {
      const item = await queue.take();
      if (item === null) {
        if (pending === 0) queue.finish();
        break;
      }

      const { url, depth } = item;

      const filePath = urlToFilePath(url);
      if (fs.existsSync(filePath)) {
        console.log(`[W${workerIdx}] Skipping (exists): ${url}`);
        if (recursive) {
          const html = fs.readFileSync(filePath, 'utf-8');
          enqueueLinks(html, url, depth);
        }
        pending--;
        if (pending === 0 && queue.length === 0 && !queue.isDone) queue.finish();
        continue;
      }

      // Apply wait between retrievals
      if (lastDownloadTime > 0 && (waitSeconds > 0 || randomWait)) {
        await applyWait();
      }

      console.log(`[W${workerIdx}] Fetching: ${url}`);
      const result = await fetchPage(url);

      if (result) {
        const savedPath = savePage(url, result.rendered);
        runPostProcess(savedPath);
        downloaded++;
        lastDownloadTime = Date.now();

        if (recursive) {
          enqueueLinks(result.rendered, url, depth);
        }
      }

      pending--;
      if (pending === 0 && queue.length === 0 && !queue.isDone) queue.finish();
    }
  }

  // Start all workers concurrently
  const workers = [];
  for (let i = 0; i < parallelism; i++) {
    workers.push(worker(i));
  }
  await Promise.all(workers);

  console.log(`\nDone. Downloaded ${downloaded} page(s), ${visited.size} total visited.`);

  // Cleanup: close WebSockets and kill Chrome
  for (const s of sessions) {
    try { if (s.ws && s.ws.readyState === 1) s.ws.close(); } catch {}
  }
  await new Promise(r => setTimeout(r, 500));
  for (const p of chromeProcs) {
    try { p.kill('SIGTERM'); } catch {}
  }
  setTimeout(() => {
    for (const p of chromeProcs) { try { p.kill('SIGKILL'); } catch {} }
    process.exit(0);
  }, 1000);
}

main().catch((e) => {
  console.error(e.message);
  process.exit(1);
});
